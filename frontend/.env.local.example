# Copy to .env.local and adjust. Never commit .env.local.

# Backend MotoAgora (use empty string in dev = same origin + Vite proxy /api/v1)
# VITE_API_URL=

# --- Rastrosystem API ---
# Full origin (default if unset): https://teste.rastrosystem.com.br
# VITE_RASTRO_API_BASE=https://teste.rastrosystem.com.br

# Local dev: avoid browser CORS by proxying through Vite (see vite.config.ts).
# Set base to the same path as the dev-server proxy prefix:
# VITE_RASTRO_API_BASE=/api/rastro

# Optional: override proxy target when using /api/rastro (defaults to teste host).
# VITE_RASTRO_PROXY_TARGET=https://teste.rastrosystem.com.br

# `app` field on POST /api_v2/login/ (default 9 if unset).
# VITE_RASTRO_APP_ID=9

# When "true", login/buscar/veiculo-update are mocked — no real credentials needed.
# VITE_RASTRO_MOCK=true
