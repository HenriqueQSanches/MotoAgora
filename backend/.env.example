# Opcao A (recomendado no Windows): usuario/senha separados — senha com @ # etc. funciona sem encoding manual
POSTGRES_USER=moto
POSTGRES_PASSWORD=moto
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=motoagora

# Opcao B: uma linha so — se a senha tiver @ ou # use percent-encoding (ex.: @ -> %40)
# DATABASE_URL=postgresql+psycopg2://moto:moto@localhost:5432/motoagora

REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Use o mesmo dominio do painel (ex.: motoagora.rastrosystem.com.br). teste.* e outro ambiente!
RASTRO_API_BASE=https://motoagora.rastrosystem.com.br
RASTRO_APP_ID=9
WHATSAPP_ENABLED=false
SGLOCK_ENABLED=false
